# KnozySunucu Environment Variables Template
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun

# JWT Secret - Güvenli bir secret key girin
JWT_SECRET=your-super-secret-key-change-this

# Server Port
PORT=8080

# CurseForge API Key - https://console.curseforge.com/ adresinden alın
CURSEFORGE_API_KEY=your_api_key_here

# Minecraft Server Path - Sunucunuzun ana dizini
MINECRAFT_SERVER_PATH=/root/site/KnozySunucu/sunucular

# Minecraft Server JAR dosyası
MINECRAFT_SERVER_JAR=forge-server.jar

# Minecraft Max/Min RAM
MINECRAFT_MAX_RAM=4G
MINECRAFT_MIN_RAM=2G

# Backup dizini
BACKUP_PATH=/root/site/KnozySunucu/yedekler
